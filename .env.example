# ================================================
# YYC³ Family-AI 环境变量配置模板
# ================================================
# 复制此文件为 .env 并填写实际值
# cp .env.example .env
#
# ⚠️ 开源安全原则：
# - 所有配置存储在本地浏览器 (localStorage / IndexedDB)
# - 不收集任何用户个人信息
# - API调用直接发往用户配置的第三方服务
# - 支持完全离线使用（除AI功能外）
# ================================================

# ================================================
# 基础配置
# ================================================

# 应用端口 (默认: 3200)
PORT=3200

# 时区 (默认: Asia/Shanghai)
TZ=Asia/Shanghai

# 运行环境 (development | production)
NODE_ENV=production

# ================================================
# YYC³ 官方网关 (可选)
# ================================================
# 默认网关地址，用户可在UI中覆盖此设置
VITE_YYC3_GATEWAY_URL=https://api.0379.world
VITE_YYC3_GATEWAY_DOCS=/docs

# ================================================
# AI 服务配置 (可选)
# ================================================
# 注意: 这些配置仅用于服务端代理
# 客户端模式下，用户在 UI 中自行配置 API Key

# OpenAI
# VITE_OPENAI_API_KEY=sk-xxx
# VITE_OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic (Claude)
# VITE_ANTHROPIC_API_KEY=sk-ant-xxx
# VITE_ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# DeepSeek
# VITE_DEEPSEEK_API_KEY=sk-xxx
# VITE_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 智谱 AI
# VITE_ZHIPU_API_KEY=xxx.xxx
# VITE_ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Moonshot AI
# VITE_MOONSHOT_API_KEY=sk-xxx
# VITE_MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# 通义千问
# VITE_QWEN_API_KEY=sk-xxx
# VITE_QWEN_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# ================================================
# 监控配置 (可选)
# ================================================

# Sentry 错误追踪
# VITE_SENTRY_DSN=https://xxx@sentry.io/xxx
# VITE_SENTRY_ENVIRONMENT=production
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# ================================================
# 功能开关 (可选)
# ================================================

# 启用 PWA 离线模式
VITE_ENABLE_PWA=true

# 启用性能监控
VITE_ENABLE_PERFORMANCE_MONITOR=true

# 启用调试模式
VITE_DEBUG=false

# ================================================
# 安全配置 (可选)
# ================================================

# CSP 报告端点
# VITE_CSP_REPORT_URI=https://xxx/report

# 允许的外部域名 (逗号分隔)
# VITE_ALLOWED_ORIGINS=https://example.com,https://api.example.com

# ================================================
# 企业部署配置 (可选)
# ================================================

# 企业名称 (显示在 UI)
# VITE_ENTERPRISE_NAME=My Company

# 企业 Logo URL
# VITE_ENTERPRISE_LOGO=https://example.com/logo.png

# 帮助文档 URL
# VITE_HELP_URL=https://docs.example.com

# 反馈 URL
# VITE_FEEDBACK_URL=https://feedback.example.com

# ================================================
# Docker Compose 配置
# ================================================

# Compose 项目名称
COMPOSE_PROJECT_NAME=yyc3-family-ai

# 数据卷路径
# DATA_PATH=./data

# 日志级别
LOG_LEVEL=info
