# ================================================================
# YYC3 Family AI - 环境变量配置示例
# ================================================================
# 复制此文件为 .env.local 并填入实际配置
# ================================================================

# ---------------------------------------------------------------
# 应用配置
# ---------------------------------------------------------------
NODE_ENV=development
VITE_APP_VERSION=0.0.1
VITE_APP_NAME=YYC3 Family AI

# ---------------------------------------------------------------
# Sentry 错误追踪
# ---------------------------------------------------------------
# 获取 DSN: https://sentry.io/settings/your-org/projects/your-project/keys/
VITE_SENTRY_DSN=https://your_public_key@o0.ingest.sentry.io/your_project_id

# Sentry 配置 (可选)
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_SAMPLE_RATE=1.0
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# ---------------------------------------------------------------
# LLM Provider API Keys (可选，用户可在设置中配置)
# ---------------------------------------------------------------
# Ollama (本地，无需 Key)
# ZhipuAI (智谱)
VITE_ZHIPU_API_KEY=43b12c5a3a1a464eb4399413289133f5.QV8iwaUwsrNrKYQy
# DashScope (通义千问)
VITE_DASHSCOPE_API_KEY=sk-af9aab1ac5084e0e91476def190f793d
# OpenAI
VITE_OPENAI_API_KEY=your_openai_api_key
# DeepSeek
VITE_DEEPSEEK_API_KEY=sk-c92c2bc6d4814ed1b230610b9c40532c

# ---------------------------------------------------------------
# 其他服务配置
# ---------------------------------------------------------------
# WebSocket 服务器地址 (实时协作)
VITE_WEBSOCKET_URL=ws://localhost:8080

# API 基础地址
VITE_API_BASE_URL=https://api.yyc3.com

# ---------------------------------------------------------------
# 功能开关
# ---------------------------------------------------------------
VITE_ENABLE_SENTRY=true
VITE_ENABLE_WEBSOCKET=false
VITE_ENABLE_MULTI_INSTANCE=true

# ---------------------------------------------------------------
# 开发配置
# ---------------------------------------------------------------
# 开发环境建议关闭 Sentry 或降低采样率
# 生产环境建议降低采样率以节省配额
