{"compilerOptions": {"target": "ES2020", "useDefineForClassFields": true, "lib": ["ES2020", "DOM"], "module": "ESNext", "skipLibCheck": true, /* Bundler mode */ "moduleResolution": "bundler", "allowImportingTsExtensions": true, "isolatedModules": true, "moduleDetection": "force", "noEmit": true, "jsx": "react-jsx", /* Linting - TypeScript 6.0 defaults */ "strict": true, "noUnusedLocals": false, "noUnusedParameters": false, "noFallthroughCasesInSwitch": true, "forceConsistentCasingInFileNames": true, /* TypeScript 6.0: 移除已弃用的baseUrl，使用rootDir + paths */ "rootDir": ".", /* Aliases - 保持@/*路径映射正常工作 */ "paths": {"@/*": ["./src/*"]}, /* Types */ "types": ["vitest/globals"]}, "include": ["src"], "exclude": ["node_modules", "dist", "coverage", "src/imports", "src/stories"]}