# ================================================================
# CDN 加速配置
# ================================================================
# 说明：复制此文件为 .env.cdn 并根据需要修改配置
# 使用方式：pnpm dev --mode cdn 或 pnpm build --mode cdn
# ================================================================

# 是否启用 CDN 加速（true/false）
USE_CDN=true

# CDN 基础 URL（可选，默认使用 jsDelivr）
# 可选值：
#   - https://cdn.jsdelivr.net/npm (推荐，全球节点多)
#   - https://unpkg.com (备选)
#   - https://cdnjs.cloudflare.com (备选)
CDN_BASE_URL=https://cdn.jsdelivr.net/npm

# ================================================================
# CDN 包版本配置
# ================================================================
# 注意：版本号必须与 package.json 中的依赖版本匹配

# React 核心库
CDN_REACT_VERSION=18.3.1
CDN_REACT_DOM_VERSION=18.3.1

# 状态管理
CDN_ZUSTAND_VERSION=5.0.2

# ================================================================
# 高级配置
# ================================================================

# CDN 回退策略（当 CDN 加载失败时的处理）
CDN_FALLBACK=true

# CDN 缓存时间（秒）
CDN_CACHE_TTL=3600

# 是否使用本地缓存
CDN_USE_CACHE=true