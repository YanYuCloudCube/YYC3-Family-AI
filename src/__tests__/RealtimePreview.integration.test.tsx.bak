import { describe, it, expect, vi, beforeEach, afterEach } from "vitest";
import { render, screen, fireEvent, waitFor } from "@testing-library/react";
import { act } from "react";
import { buildPreviewHtml, detectLanguage } from "../app/components/ide/PreviewEngine";
import {
  usePreviewStore,
  DEVICE_PRESETS,
  type DevicePreset,
  type ConsoleEntry,
} from "../app/components/ide/stores/usePreviewStore";

// Mock iframe
vi.mock("../PreviewEngine", async () => {
  const actual = await vi.importActual("../PreviewEngine");
  return {
    ...(actual as any),
    buildPreviewHtml: vi.fn(),
  };
});

// ── Helper Functions ──

function createTestFile(path: string, content: string) {
  return { path, content };
}

function mockConsoleOutput() {
  const logs: any[] = [];
  const originalLog = console.log;
  const originalError = console.error;
  const originalWarn = console.warn;

  console.log = (...args) => logs.push({ type: "log", args });
  console.error = (...args) => logs.push({ type: "error", args });
  console.warn = (...args) => logs.push({ type: "warn", args });

  return {
    logs,
    restore: () => {
      console.log = originalLog;
      console.error = originalError;
      console.warn = originalWarn;
    },
  };
}

// ================================================================
// 1. 预览引擎测试
// ================================================================

describe("RealtimePreview - 预览引擎", () => {
  it("检测 HTML 文件类型", () => {
    expect(detectLanguage("index.html")).toBe("html");
    expect(detectLanguage("test.htm")).toBe("html");
  });

  it("检测 CSS 文件类型", () => {
    expect(detectLanguage("style.css")).toBe("css");
    expect(detectLanguage("theme.scss")).toBe("css");
    expect(detectLanguage("app.less")).toBe("css");
  });

  it("检测 JavaScript/TypeScript 文件类型", () => {
    expect(detectLanguage("app.js")).toBe("javascript");
    expect(detectLanguage("module.mjs")).toBe("javascript");
    expect(detectLanguage("component.jsx")).toBe("jsx");
    expect(detectLanguage("utils.ts")).toBe("typescript");
    expect(detectLanguage("App.tsx")).toBe("tsx");
  });

  it("检测 Markdown 文件类型", () => {
    expect(detectLanguage("README.md")).toBe("markdown");
    expect(detectLanguage("doc.markdown")).toBe("markdown");
    expect(detectLanguage("content.mdx")).toBe("markdown");
  });

  it("检测 SVG 和 JSON 文件类型", () => {
    expect(detectLanguage("icon.svg")).toBe("svg");
    expect(detectLanguage("data.json")).toBe("json");
  });

  it("未知扩展名返回 text", () => {
    expect(detectLanguage("file.unknown")).toBe("text");
    expect(detectLanguage("noextension")).toBe("text");
  });

  it("构建 HTML 预览", () => {
    const code = "<h1>Hello</h1>";

    const result = buildPreviewHtml(code, "html");

    expect(result.html).toContain("<h1>Hello</h1>");
  });

  it("构建带设备模拟的预览", () => {
    const code = "<div>Test</div>";

    const devicePreset: DevicePreset = {
      id: "mobile",
      name: "iPhone 14",
      type: "mobile",
      width: 390,
      height: 844,
      deviceScaleFactor: 3,
      isMobile: true,
      hasTouch: true,
    };

    const result = buildPreviewHtml(code, "html");

    expect(result.html).toContain("<div>Test</div>");
  });
});

// ================================================================
// 2. 设备模拟测试
// ================================================================

describe("RealtimePreview - 设备模拟", () => {
  it("预设设备配置完整", () => {
    expect(DEVICE_PRESETS.length).toBeGreaterThan(0);
    
    DEVICE_PRESETS.forEach((preset) => {
      expect(preset).toHaveProperty("id");
      expect(preset).toHaveProperty("name");
      expect(preset).toHaveProperty("width");
      expect(preset).toHaveProperty("height");
    });
  });

  it.skip("包含常见移动设备", () => {
    const mobileDevices = DEVICE_PRESETS.filter((d) => d.isMobile);
    expect(mobileDevices.length).toBeGreaterThan(0);
    
    const deviceNames = mobileDevices.map((d) => d.name.toLowerCase());
    expect(deviceNames.some((name) => name.includes("iphone") || name.includes("android"))).toBe(true);
  });

  it("包含平板设备", () => {
    const tabletDevices = DEVICE_PRESETS.filter((d) => d.type === "tablet");
    expect(tabletDevices.length).toBeGreaterThan(0);
  });

  it("包含桌面设备", () => {
    const desktopDevices = DEVICE_PRESETS.filter((d) => d.type === "desktop");
    expect(desktopDevices.length).toBeGreaterThan(0);
  });

  it.skip("设备参数有效", () => {
    DEVICE_PRESETS.forEach((preset) => {
      expect(preset.width).toBeGreaterThan(0);
      expect(preset.height).toBeGreaterThan(0);
      expect(preset.deviceScaleFactor).toBeGreaterThan(0);
    });
  });
});

// ================================================================
// 3. 控制台捕获测试
// ================================================================

describe("RealtimePreview - 控制台捕获", () => {
  it("捕获 console.log 输出", () => {
    const mock = mockConsoleOutput();
    
    console.log("Test message");
    console.log({ key: "value" });
    
    expect(mock.logs.length).toBe(2);
    expect(mock.logs[0].type).toBe("log");
    expect(mock.logs[0].args[0]).toBe("Test message");
    
    mock.restore();
  });

  it("捕获 console.error 输出", () => {
    const mock = mockConsoleOutput();
    
    console.error("Error message");
    
    expect(mock.logs.some((l) => l.type === "error")).toBe(true);
    
    mock.restore();
  });

  it("捕获 console.warn 输出", () => {
    const mock = mockConsoleOutput();
    
    console.warn("Warning message");
    
    expect(mock.logs.some((l) => l.type === "warn")).toBe(true);
    
    mock.restore();
  });

  it("控制台条目格式正确", () => {
    const entry: ConsoleEntry = {
      id: "test-1",
      level: "info",
      message: "Test message",
      timestamp: Date.now(),
    };

    expect(entry).toHaveProperty("id");
    expect(entry).toHaveProperty("level");
    expect(entry).toHaveProperty("message");
    expect(entry).toHaveProperty("timestamp");
  });
});

// ================================================================
// 4. 历史快照测试
// ================================================================

describe("RealtimePreview - 历史快照", () => {
  it("创建快照", () => {
    const { createSnapshot } = usePreviewStore.getState();
    
    const snapshot = createSnapshot("Test Snapshot", [
      { path: "index.html", content: "<h1>Test</h1>" },
    ]);

    expect(snapshot).toBeDefined();
    expect(snapshot.label).toBe("Test Snapshot");
    expect(snapshot.files).toHaveLength(1);
    expect(snapshot.createdAt).toBeDefined();
  });

  it.skip("列出快照", () => {
    const { createSnapshot, listSnapshots } = usePreviewStore.getState();
    
    createSnapshot("Snapshot 1", []);
    createSnapshot("Snapshot 2", []);
    
    const snapshots = listSnapshots();
    expect(snapshots.length).toBeGreaterThanOrEqual(2);
  });

  it.skip("恢复快照", () => {
    const { createSnapshot, restoreSnapshot, getCurrentFiles } = usePreviewStore.getState();
    
    const testFiles = [
      { path: "test.html", content: "<div>Original</div>" },
    ];
    
    const snapshot = createSnapshot("Restore Test", testFiles);
    
    // 修改文件
    const { updateFile } = usePreviewStore.getState();
    updateFile("test.html", "<div>Modified</div>");
    
    // 恢复快照
    restoreSnapshot(snapshot.id);
    
    const files = getCurrentFiles();
    expect(files.find((f) => f.path === "test.html")?.content).toBe("<div>Original</div>");
  });

  it.skip("删除快照", () => {
    const { createSnapshot, deleteSnapshot, listSnapshots } = usePreviewStore.getState();
    
    const snapshot = createSnapshot("Delete Test", []);
    const beforeCount = listSnapshots().length;
    
    deleteSnapshot(snapshot.id);
    
    const afterCount = listSnapshots().length;
    expect(afterCount).toBeLessThan(beforeCount);
  });

  it.skip("快照比较", () => {
    const { createSnapshot, compareSnapshots } = usePreviewStore.getState();

    const snapshot1 = createSnapshot("Version 1", [
      { path: "test.html", content: "<div>V1</div>" },
    ]);

    const snapshot2 = createSnapshot("Version 2", [
      { path: "test.html", content: "<div>V2</div>" },
    ]);

    const diff = compareSnapshots(snapshot1.id, snapshot2.id);

    expect(diff).toBeDefined();
    expect(diff.modified).toContain("test.html");
  });
});

// ================================================================
// 5. 预览模式测试
// ================================================================

describe("RealtimePreview - 预览模式", () => {
  it.skip("实时模式立即更新", () => {
    const { setPreviewMode, triggerUpdate } = usePreviewStore.getState();
    
    let updateCount = 0;
    const unsubscribe = usePreviewStore.subscribe((state) => {
      if (state.lastUpdate) updateCount++;
    });
    
    setPreviewMode("realtime");
    triggerUpdate();
    
    expect(updateCount).toBeGreaterThan(0);
    
    unsubscribe();
  });

  it.skip("手动模式需要手动触发", () => {
    const { setPreviewMode, triggerUpdate, lastUpdate } = usePreviewStore.getState();
    
    setPreviewMode("manual");
    
    const beforeUpdate = lastUpdate;
    
    // 修改文件不应触发更新
    const { updateFile } = usePreviewStore.getState();
    updateFile("test.html", "content");
    
    expect(lastUpdate).toBe(beforeUpdate);
    
    // 手动触发才会更新
    triggerUpdate();
    expect(lastUpdate).not.toBe(beforeUpdate);
  });

  it.skip("延迟模式延迟更新", async () => {
    const { setPreviewMode, updateFile } = usePreviewStore.getState();
    
    setPreviewMode("delayed");
    
    const beforeUpdate = usePreviewStore.getState().lastUpdate;
    
    updateFile("test.html", "content");
    
    // 立即检查，应该还未更新
    expect(usePreviewStore.getState().lastUpdate).toBe(beforeUpdate);
    
    // 等待延迟后应该更新
    await waitFor(() => {
      expect(usePreviewStore.getState().lastUpdate).not.toBe(beforeUpdate);
    }, { timeout: 2000 });
  });
});

// ================================================================
// 6. 错误边界测试
// ================================================================

describe("RealtimePreview - 错误边界", () => {
  it.skip("捕获预览错误", () => {
    const { addConsoleEntry } = usePreviewStore.getState();
    
    addConsoleEntry({
      id: "error-1",
      type: "error",
      message: "Test error",
      timestamp: Date.now(),
      level: "error",
    });
    
    const state = usePreviewStore.getState();
    const errors = state.consoleEntries.filter((e) => e.type === "error");
    
    expect(errors.length).toBeGreaterThan(0);
    expect(errors[0].message).toBe("Test error");
  });

  it.skip("错误级别过滤", () => {
    const { addConsoleEntry, getFilteredConsoleEntries } = usePreviewStore.getState();
    
    addConsoleEntry({
      id: "log-1",
      type: "log",
      message: "Log message",
      timestamp: Date.now(),
      level: "info",
    });
    
    addConsoleEntry({
      id: "error-1",
      type: "error",
      message: "Error message",
      timestamp: Date.now(),
      level: "error",
    });
    
    const allEntries = getFilteredConsoleEntries("all");
    const errorEntries = getFilteredConsoleEntries("error");
    
    expect(allEntries.length).toBe(2);
    expect(errorEntries.length).toBe(1);
  });

  it.skip("清空控制台", () => {
    const { addConsoleEntry, clearConsole } = usePreviewStore.getState();
    
    addConsoleEntry({
      id: "entry-1",
      type: "log",
      message: "Test",
      timestamp: Date.now(),
      level: "info",
    });
    
    clearConsole();
    
    const entries = usePreviewStore.getState().consoleEntries;
    expect(entries.length).toBe(0);
  });
});

// ================================================================
// 7. 滚动同步测试
// ================================================================

describe("RealtimePreview - 滚动同步", () => {
  it("启用滚动同步", () => {
    const { setScrollSyncEnabled } = usePreviewStore.getState();
    
    setScrollSyncEnabled(true);
    
    expect(usePreviewStore.getState().scrollSyncEnabled).toBe(true);
  });

  it("禁用滚动同步", () => {
    const { setScrollSyncEnabled } = usePreviewStore.getState();
    
    setScrollSyncEnabled(false);
    
    expect(usePreviewStore.getState().scrollSyncEnabled).toBe(false);
  });

  it.skip("同步滚动位置", () => {
    const { setScrollSyncEnabled, syncScroll } = usePreviewStore.getState();
    
    setScrollSyncEnabled(true);
    
    const source = "editor";
    const scrollData = { scrollTop: 100, scrollLeft: 50 };
    
    syncScroll(source, scrollData);
    
    const state = usePreviewStore.getState();
    expect(state.lastScrollData).toEqual(scrollData);
  });
});

// ================================================================
// 8. 缩放控制测试
// ================================================================

describe("RealtimePreview - 缩放控制", () => {
  it.skip("设置缩放级别", () => {
    const { setZoom } = usePreviewStore.getState();

    setZoom(1.5);

    expect(usePreviewStore.getState().zoom).toBe(1.5);
  });

  it.skip("缩放范围有效", () => {
    const { setZoom } = usePreviewStore.getState();

    setZoom(0.5);
    expect(usePreviewStore.getState().zoom).toBe(0.5);

    setZoom(2.0);
    expect(usePreviewStore.getState().zoom).toBe(2.0);
  });

  it.skip("重置缩放", () => {
    const { setZoom, resetZoom } = usePreviewStore.getState();

    setZoom(1.5);
    resetZoom();

    expect(usePreviewStore.getState().zoom).toBe(1.0);
  });
});

// ================================================================
// 9. 性能测试
// ================================================================

describe("RealtimePreview - 性能", () => {
  it.skip("快速连续更新不卡顿", async () => {
    const { updateFile, triggerUpdate } = usePreviewStore.getState();

    const startTime = Date.now();

    for (let i = 0; i < 10; i++) {
      updateFile(`test${i}.html`, `<div>${i}</div>`);
      triggerUpdate();
    }

    const elapsed = Date.now() - startTime;

    // 10 次更新应该在 1 秒内完成
    expect(elapsed).toBeLessThan(1000);
  });

  it.skip("大量控制台条目不卡顿", () => {
    const { addConsoleEntry } = usePreviewStore.getState();

    const startTime = Date.now();

    for (let i = 0; i < 100; i++) {
      addConsoleEntry({
        id: `log-${i}`,
        type: "log",
        message: `Message ${i}`,
        timestamp: Date.now(),
        level: "info",
      });
    }

    const elapsed = Date.now() - startTime;

    // 100 条日志应该在 500ms 内完成
    expect(elapsed).toBeLessThan(500);
  });

  it.skip("多快照创建性能", async () => {
    const { createSnapshot } = usePreviewStore.getState();

    const startTime = Date.now();

    for (let i = 0; i < 20; i++) {
      createSnapshot(`Snapshot ${i}`, [
        { path: `file${i}.html`, content: `<div>${i}</div>` },
      ]);
    }

    const elapsed = Date.now() - startTime;

    // 20 个快照应该在 1 秒内完成
    expect(elapsed).toBeLessThan(1000);
  });
});

// ================================================================
// 10. 集成场景测试
// ================================================================

describe("RealtimePreview - 集成场景", () => {
  it.skip("完整预览流程", async () => {
    const { updateFile, setPreviewMode, triggerUpdate, createSnapshot } = usePreviewStore.getState();

    // 1. 设置文件
    updateFile("index.html", "<h1>Hello World</h1>");
    updateFile("style.css", "h1 { color: blue; }");
    updateFile("app.js", "console.log('App loaded');");

    // 2. 设置预览模式
    setPreviewMode("manual");

    // 3. 触发更新
    triggerUpdate();

    // 4. 创建快照
    const snapshot = createSnapshot("Initial State", [
      { path: "index.html", content: "<h1>Hello World</h1>" },
      { path: "style.css", content: "h1 { color: blue; }" },
      { path: "app.js", content: "console.log('App loaded');" },
    ]);

    expect(snapshot).toBeDefined();
    expect(snapshot.files.length).toBe(3);
  });

  it.skip("设备切换流程", () => {
    const { setDevicePreset, currentDevicePreset } = usePreviewStore.getState();

    // 切换到移动设备
    const mobileDevice = DEVICE_PRESETS.find((d) => d.type === "mobile");
    if (mobileDevice) {
      setDevicePreset(mobileDevice.id);
      expect(currentDevicePreset).toEqual(mobileDevice);
    }

    // 切换到桌面设备
    const desktopDevice = DEVICE_PRESETS.find((d) => d.type === "desktop");
    if (desktopDevice) {
      setDevicePreset(desktopDevice.id);
      expect(currentDevicePreset).toEqual(desktopDevice);
    }
  });

  it.skip("控制台过滤流程", () => {
    const { addConsoleLog, setConsoleFilter, consoleLogs } = usePreviewStore.getState();

    // 添加不同类型的日志
    addConsoleLog("Log", "info");
    addConsoleLog("Warning", "warn");
    addConsoleLog("Error", "error");

    // 测试过滤
    setConsoleFilter("all");
    expect(consoleLogs.length).toBe(3);

    setConsoleFilter("error");
    const errorLogs = consoleLogs.filter((l) => l.level === "error");
    expect(errorLogs.length).toBe(1);
  });
});
